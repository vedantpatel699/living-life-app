        {"day": 2, "pattern": "Run 90s / Walk 2min × 6", "intervals": [{"phase":"warmup","sec":300},{"phase":"run","sec":90,"repeat":6,"recovery":{"phase":"walk","sec":120}},{"phase":"cooldown","sec":300}], "totalMin": 30},
        {"day": 3, "pattern": "Run 90s / Walk 2min × 6", "intervals": [{"phase":"warmup","sec":300},{"phase":"run","sec":90,"repeat":6,"recovery":{"phase":"walk","sec":120}},{"phase":"cooldown","sec":300}], "totalMin": 30}
      ]
    },
