        {"day": 2, "pattern": "R3min W90s R5min W2.5min R3min W90s R5min", "intervals": [{"phase":"warmup","sec":300},{"phase":"run","sec":180},{"phase":"walk","sec":90},{"phase":"run","sec":300},{"phase":"walk","sec":150},{"phase":"run","sec":180},{"phase":"walk","sec":90},{"phase":"run","sec":300},{"phase":"cooldown","sec":300}], "totalMin": 32},
