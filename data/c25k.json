        {"day": 3, "pattern": "(R90s W90s, R3min W3min) × 2", "intervals": [{"phase":"warmup","sec":300},{"phase":"run","sec":90},{"phase":"walk","sec":90},{"phase":"run","sec":180},{"phase":"walk","sec":180},{"phase":"run","sec":90},{"phase":"walk","sec":90},{"phase":"run","sec":180},{"phase":"walk","sec":180},{"phase":"cooldown","sec":300}], "totalMin": 28}
