  "note": "Full Couch-to-5K program per Josh Clark original. 9 weeks × 3 sessions/week = 27 sessions. Each session has 5 min warm-up walk + intervals + 5 min cooldown walk. Some weeks have different sessions per day.",
  "weeks": [
    {
      "week": 1,
      "label": "Welcome to running",
      "guidance": "Start slow. Don't sprint the run intervals — jog pace = could still talk in short sentences.",
      "sessions": [
        {"day": 1, "pattern": "Run 60s / Walk 90s × 8", "intervals": [{"phase":"warmup","sec":300},{"phase":"run","sec":60,"repeat":8,"recovery":{"phase":"walk","sec":90}},{"phase":"cooldown","sec":300}], "totalMin": 25},
        {"day": 2, "pattern": "Run 60s / Walk 90s × 8", "intervals": [{"phase":"warmup","sec":300},{"phase":"run","sec":60,"repeat":8,"recovery":{"phase":"walk","sec":90}},{"phase":"cooldown","sec":300}], "totalMin": 25},
        {"day": 3, "pattern": "Run 60s / Walk 90s × 8", "intervals": [{"phase":"warmup","sec":300},{"phase":"run","sec":60,"repeat":8,"recovery":{"phase":"walk","sec":90}},{"phase":"cooldown","sec":300}], "totalMin": 25}
      ]
    },
    {
      "week": 2,
      "label": "Slightly longer runs",
